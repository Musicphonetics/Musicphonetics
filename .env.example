# ---------------------------------------------------------------------------
# Musicphonetics - environment variables
# Copy to .env.local for local `next build`/`next dev` (this file is committed;
# .env.local is git-ignored). PRODUCTION values are set in the Cloudflare Pages
# dashboard (Settings -> Environment variables), NOT here.
# ---------------------------------------------------------------------------

# Supabase (client - safe, protected by RLS)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Razorpay - PUBLISHABLE key id (safe in the browser bundle)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Razorpay - SERVER ONLY. Do NOT put these in .env.local for a static build;
# they are read by the Cloudflare Pages Functions. Set them in the Cloudflare
# dashboard (and in .dev.vars for local `wrangler pages dev`). Never expose the
# secret to the browser.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_key_secret_here
